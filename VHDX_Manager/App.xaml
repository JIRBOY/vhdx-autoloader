<Application x:Class="VHDX_Manager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:VHDX_Manager"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <!-- 全局资源 -->
        <ResourceDictionary>
            <!-- 全局字体 -->
            <FontFamily x:Key="DefaultFont">Segoe UI</FontFamily>

            <!-- 全局颜色 -->
            <Color x:Key="PrimaryColor">#2196F3</Color>
            <Color x:Key="PrimaryDarkColor">#1976D2</Color>
            <Color x:Key="AccentColor">#FF9800</Color>
            <Color x:Key="SuccessColor">#4CAF50</Color>
            <Color x:Key="ErrorColor">#F44336</Color>
            <Color x:Key="WarningColor">#FF9800</Color>
            <Color x:Key="TextPrimaryColor">#212121</Color>
            <Color x:Key="TextSecondaryColor">#757575</Color>
            <Color x:Key="DividerColor">#E0E0E0</Color>
            <Color x:Key="BackgroundColor">#F5F5F5</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>